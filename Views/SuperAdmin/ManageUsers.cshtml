@model IEnumerable<UrbanGadgetsMS.Models.User>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Users";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Manage Businesses</h5>
    </div>

    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fa-solid fa-circle-check me-2"></i>
                @TempData["Success"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert">
                </button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fa-solid fa-circle-exclamation me-2"></i>
                @TempData["Error"]

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert">
                </button>
            </div>
        }

        <table class="table table-bordered table-hover">

            <thead class="table-dark">
                <tr>
                    <th>Business</th>
                    <th>Admin</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th width="320">Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var user in Model)
                {
                    <tr>

                        <td>@user.Business?.BusinessName</td>

                        <td>@user.FullName</td>

                        <td>

                            <form asp-action="ChangeRole" method="post">

                                <input type="hidden"
                                       name="id"
                                       value="@user.Id" />

                                <select name="role"
                                        class="form-select form-select-sm">

                                    <option value="Admin"
                                            selected="@(user.Role == "Admin")">
                                        Admin
                                    </option>

                                    <option value="Cashier"
                                            selected="@(user.Role == "Cashier")">
                                        Cashier
                                    </option>

                                </select>

                                <button class="btn btn-sm btn-primary mt-2">
                                    Save
                                </button>

                            </form>

                        </td>

                        <td>

                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Suspended
                                </span>
                            }

                        </td>

                        <td>

                            <button class="btn btn-sm btn-info"
                                    onclick="loadUsers(@user.BusinessId)">
                                View Users
                            </button>

                            @if (user.IsActive)
                            {
                                <form asp-action="Suspend"
                                      method="post"
                                      style="display:inline;">

                                    <input type="hidden"
                                           name="id"
                                           value="@user.Id" />

                                    <button class="btn btn-sm btn-warning">
                                        Suspend
                                    </button>

                                </form>
                            }
                            else
                            {
                                <form asp-action="Activate"
                                      method="post"
                                      style="display:inline;">

                                    <input type="hidden"
                                           name="id"
                                           value="@user.Id" />

                                    <button class="btn btn-sm btn-success">
                                        Activate
                                    </button>

                                </form>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>

<div class="modal fade"
     id="usersModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">
                    Business Users
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <div id="usersContainer">

                    <div class="text-center">
                        Loading...
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts{

    <script>

        async function loadUsers(businessId)
        {
            const response =
                await fetch(`/SuperAdmin/ViewUsers?businessId=${businessId}`);

            const users = await response.json();

            let html = `
                <table class="table table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Username</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th width="250">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            users.forEach(u => {

                html += `
                    <tr>

                        <td>${u.fullName}</td>

                        <td>${u.username}</td>

                        <td>${u.role}</td>

                        <td>
                            ${u.isActive
                                ? '<span class="badge bg-success">Active</span>'
                                : '<span class="badge bg-danger">Disabled</span>'}
                        </td>

                                <td>

            <form method="post"
                  action="/SuperAdmin/ChangeRole"
                  class="mb-1">

                <input type="hidden"
                       name="id"
                       value="${u.id}" />

                <div class="d-flex gap-1">

                    <select name="role"
                            class="form-select form-select-sm">

                        <option value="Admin"
                            ${u.role === "Admin" ? "selected" : ""}>
                            Admin
                        </option>

                        <option value="Cashier"
                            ${u.role === "Cashier" ? "selected" : ""}>
                            Cashier
                        </option>

                    </select>

                    <button class="btn btn-sm btn-primary">
                        Save
                    </button>

                </div>

            </form>

            ${
                u.isActive
                ?
                `<form method="post"
                       action="/SuperAdmin/DisableUser"
                       style="display:inline;">
                     <input type="hidden"
                            name="id"
                            value="${u.id}" />
                     <button class="btn btn-sm btn-warning">
                         Disable
                     </button>
                 </form>`
                :
                `<form method="post"
                       action="/SuperAdmin/EnableUser"
                       style="display:inline;">
                     <input type="hidden"
                            name="id"
                            value="${u.id}" />
                     <button class="btn btn-sm btn-success">
                         Enable
                     </button>
                 </form>`
            }

            <form method="post"
                  action="/SuperAdmin/ResetPassword"
                  style="display:inline;">

                <input type="hidden"
                       name="id"
                       value="${u.id}" />

                <button class="btn btn-sm btn-secondary">
                    Reset
                </button>

            </form>

            <form method="post"
                  action="/SuperAdmin/DeleteUser"
                  style="display:inline;"
                  onsubmit="return confirm('Delete this user permanently?');">

                <input type="hidden"
                       name="id"
                       value="${u.id}" />

                <button class="btn btn-sm btn-danger">
                    Delete
                </button>

            </form>

        </td>

                    </tr>
                `;
            });

            html += `
                    </tbody>
                </table>
            `;

            document.getElementById("usersContainer").innerHTML = html;

            let modal =
                new bootstrap.Modal(
                    document.getElementById("usersModal")
                );

            modal.show();
        }

    </script>

}
@model UrbanGadgets.ViewModels.LoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>UrbanGadgets Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

    <style>
        body{
            background:#0f172a;
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            color:white;
        }

        .login-box{
            width:420px;
            background:#111827;
            padding:40px;
            border-radius:20px;
            box-shadow:0 0 30px rgba(0,0,0,.4);
        }

        .logo{
            font-size:28px;
            font-weight:bold;
            text-align:center;
            margin-bottom:25px;
            color:#38bdf8;
        }

        .form-control{
            background:#1f2937;
            border:none;
            color:white;
            height:50px;
        }

        .form-control:focus{
            background:#1f2937;
            color:white;
            box-shadow:none;
            border:1px solid #38bdf8;
        }

        .btn-login{
            height:50px;
            border-radius:10px;
            background:#2563eb;
            border:none;
            font-weight:bold;
        }
    </style>
</head>
<body>

    <div class="login-box">
        <div class="logo">
            <i class="fa-solid fa-store"></i> UrbanGadgets
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label>Username</label>
                <input asp-for="Username" class="form-control" placeholder="Enter username" />
            </div>

            <div class="mb-4">
                <label>Password</label>
                <input asp-for="Password" class="form-control" placeholder="Enter password" />
            </div>

            <button class="btn btn-primary btn-login w-100">
                <i class="fa-solid fa-right-to-bracket"></i> Login
            </button>
        </form>
    </div>

</body>
</html>
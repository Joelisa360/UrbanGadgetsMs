@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Enter PIN - UrbanGadgets</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #0f172a, #1e3a8a);
            font-family: 'Segoe UI', sans-serif;
        }

        .pin-card {
            width: 420px;
            background: rgba(255,255,255,.95);
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 25px 60px rgba(0,0,0,.25);
            text-align: center;
            animation: fadeUp .5s ease;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(25px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .lock-icon {
            width: 90px;
            height: 90px;
            margin: auto;
            border-radius: 50%;
            background: linear-gradient(135deg,#2563eb,#1d4ed8);
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 34px;
            margin-bottom: 25px;
            box-shadow: 0 10px 25px rgba(37,99,235,.35);
        }

        .title {
            font-size: 28px;
            font-weight: 700;
            color: #0f172a;
        }

        .subtitle {
            color: #64748b;
            margin-bottom: 30px;
        }

        .pin-input {
            height: 58px;
            border-radius: 14px;
            text-align: center;
            font-size: 28px;
            letter-spacing: 12px;
            font-weight: bold;
        }

        .unlock-btn {
            height: 55px;
            border-radius: 14px;
            font-weight: 600;
            font-size: 17px;
        }

        .error-box {
            background: #fee2e2;
            color: #991b1b;
            padding: 12px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <div class="pin-card">

        <div class="lock-icon">
            <i class="fa-solid fa-lock"></i>
        </div>

        <div class="title">Security Check</div>
        <div class="subtitle">
            Enter your 4-digit PIN to continue
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                @ViewBag.Error
            </div>
        }

        <form method="post">
            <input name="pin"
                   type="password"
                   maxlength="4"
                   class="form-control pin-input mb-4"
                   placeholder="••••"
                   autofocus
                   required />

            <button class="btn btn-primary w-100 unlock-btn">
                <i class="fa-solid fa-unlock me-2"></i>
                Unlock System
            </button>
        </form>

    </div>

</body>
</html>
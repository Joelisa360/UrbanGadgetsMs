@model UrbanGadgetsMS.ViewModels.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <title>Create Account</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>

        body {
            background: #222;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .auth-card {
            width: 700px;
            background: #2d2d2d;
            color: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 0 40px rgba(0,255,255,.2);
        }

        .form-control {
            background: #3a3a3a;
            border: none;
            color: white;
        }

        .form-control:focus {
            background: #3a3a3a;
            color: white;
        }

        .btn-auth {
            background: #53c6f0;
            border: none;
            padding: 12px;
            width: 100%;
            font-size: 18px;
        }

    </style>

</head>

<body>

    <div class="auth-card">

        <h2 class="mb-4">
            Create Your Account
        </h2>

        <form asp-action="Register" method="post">

            <div asp-validation-summary="All"
                 class="text-danger mb-3">
            </div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <input asp-for="Surname"
                           class="form-control"
                           placeholder="Surname" />

                </div>

                <div class="col-md-6 mb-3">

                    <input asp-for="OtherName"
                           class="form-control"
                           placeholder="Other Name" />

                </div>

            </div>

            <div class="mb-3">

                <input asp-for="Contact"
                       class="form-control"
                       placeholder="Contact Number" />

            </div>

            <div class="mb-3">

                <input asp-for="Email"
                       class="form-control"
                       placeholder="Email Address" />

            </div>

            <div class="mb-3">

                <input asp-for="BusinessName"
                       class="form-control"
                       placeholder="Business Name" />

            </div>

            <div class="mb-3">

                <input asp-for="Username"
                       class="form-control"
                       placeholder="Username" />

            </div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <input asp-for="Password"
                           class="form-control"
                           placeholder="Password" />

                </div>

                <div class="col-md-6 mb-3">

                    <input asp-for="ConfirmPassword"
                           class="form-control"
                           placeholder="Confirm Password" />

                </div>

            </div>

            <button class="btn btn-auth">
                Request Account
            </button>

            <div class="text-center mt-4">

                Already have an account?

                <a asp-action="Login"
                   class="text-info">
                    Sign In
                </a>

            </div>

        </form>

    </div>

</body>
</html>
@using UrbanGadgetsMS.Models
@model LoginVM

@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
          rel="stylesheet">

    <style>
        body {
            background: #222;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .logo {
            font-size: 28px;
            font-weight: bold;
            color: #53c6f0;
            margin-bottom: 20px;
        }

        .auth-card {
            width: 600px;
            background: #2d2d2d;
            padding: 40px;
            border-radius: 20px;
            color: white;
            box-shadow: 0 0 40px rgba(0,255,255,.2);
        }

        .form-control {
            background: #3a3a3a;
            color: white;
            border: none;
        }

        .btn-auth {
            width: 100%;
            background: #53c6f0;
            border: none;
            padding: 12px;
        }
    </style>
</head>

<body>

    <!-- ✅ LOGO NOW CORRECTLY PLACED -->
    <div class="logo">
        <i class="fa-solid fa-store"></i> UrbanGadgets
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-3">
            @TempData["Success"]
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <div class="auth-card">

        <h2 class="mb-4">Sign in to your account</h2>

        <form asp-controller="Auth"
              asp-action="Login"
              method="post">

            <div asp-validation-summary="All"
                 class="text-danger mb-3">
            </div>

            <input asp-for="Username"
                   class="form-control mb-3"
                   placeholder="Username" />

            <input asp-for="Password"
                   type="password"
                   class="form-control mb-4"
                   placeholder="Password" />

            <button class="btn btn-auth">
                Sign In
            </button>

        </form>

        <div class="text-center mt-4">
            Don't have an account?
            <a asp-controller="Auth"
               asp-action="Register"
               class="text-info">
                Sign Up
            </a>
        </div>

    </div>

</body>
</html>
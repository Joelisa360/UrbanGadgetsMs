@model UrbanGadgetsMS.Models.Product

@{
    ViewData["Title"] = "Delete Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">

    <h2 class="text-danger mb-3">Delete Product</h2>

    <div class="alert alert-warning">
        Are you sure you want to delete this product? This action cannot be undone.
    </div>

    <div class="card shadow-sm p-3 mb-4">

        <dl class="row mb-0">

            <dt class="col-sm-3">Product Name</dt>
            <dd class="col-sm-9">@Model.ProductName</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.CategoryName</dd>

            <dt class="col-sm-3">Quantity</dt>
            <dd class="col-sm-9">@Model.Quantity</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">UGX @Model.Price.ToString("N0")</dd>

            <dt class="col-sm-3">Reorder Level</dt>
            <dd class="col-sm-9">@Model.ReorderLevel</dd>

            <dt class="col-sm-3">Date Added</dt>
            <dd class="col-sm-9">@Model.DateAdded.ToString("dd MMM yyyy")</dd>

        </dl>

    </div>

    <form asp-action="Delete" method="post">

        <input type="hidden" asp-for="Id" />

        <button type="submit"
                class="btn btn-danger"
                onclick="return confirm('Delete this product permanently?');">
            Yes, Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>
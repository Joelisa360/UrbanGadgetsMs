@model List<UrbanGadgetsMS.Models.Product>

@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    bool isAdmin = User.IsInRole("Admin");
}

<style>
    .sold-out {
        background: #e5e7eb !important;
        color: #6b7280;
    }

        .sold-out td {
            opacity: .75;
        }

    .badge-stock {
        padding: 6px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .in-stock {
        background: #dcfce7;
        color: #166534;
    }

    .low-stock {
        background: #fef3c7;
        color: #92400e;
    }

    .out-stock {
        background: #fee2e2;
        color: #991b1b;
    }

    .action-btn {
        min-width: 70px;
    }
</style>

<h2 class="fw-bold mb-3">Products</h2>

<form method="get" id="filterForm">

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">

            <div class="row g-2 align-items-center">

                <!-- SEARCH -->
                <div class="col-md-5">
                    <input type="text"
                           name="search"
                           id="searchBox"
                           value="@ViewBag.Search"
                           class="form-control"
                           placeholder="Search product..." />
                </div>

                <!-- CATEGORY -->
                <div class="col-md-3">
                    <select name="categoryId"
                            class="form-select"
                            onchange="document.getElementById('filterForm').submit()">

                        <option value="">All Categories</option>

                        @foreach (var cat in ViewBag.Categories)
                        {
                            <option value="@cat.Id"
                                    selected="@(ViewBag.CategoryId != null && ViewBag.CategoryId == cat.Id)">
                                @cat.CategoryName
                            </option>
                        }

                    </select>
                </div>

                <!-- RESET -->
                <div class="col-md-1">
                    <a asp-action="Index"
                       class="btn btn-secondary w-100">
                        ↺
                    </a>
                </div>

                <!-- ADD PRODUCT -->
                <div class="col-md-3 text-end">

                    @if (isAdmin)
                    {
                        <a asp-action="Create"
                           class="btn btn-primary w-100">
                            + Add Product
                        </a>
                    }

                </div>

            </div>

        </div>
    </div>

</form>

<script>
    let searchTimer;

    document.getElementById('searchBox')
        .addEventListener('keyup', function () {

            clearTimeout(searchTimer);

            searchTimer = setTimeout(() => {
                document.getElementById('filterForm').submit();
            }, 500); // waits 0.5 sec after typing stops
        });
</script>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Name</th>
            <th>Category</th>
            <th>Qty</th>

            @* ADMIN ONLY *@
            @if (isAdmin)
            {
                <th>Buying Price</th>
            }

            <th>Selling Price</th>
            <th>Date Added</th>
            <th width="260">Actions</th>
        </tr>
    </thead>

    <tbody>
        @{
            int no = 1;
        }

        @foreach (var item in Model)
        {
            bool soldOut = item.Quantity <= 0;

            <tr class="@(soldOut ? "sold-out" : "")">

                <td>@no</td>

                <td class="fw-semibold">
                    @item.ProductName
                </td>

                <td>
                    @item.Category?.CategoryName
                </td>

                <td>
                    @if (item.Quantity <= 0)
                    {
                        <span class="badge-stock out-stock">
                            Sold Out
                        </span>
                    }
                    else if (item.Quantity <= 5)
                    {
                        <span class="badge-stock low-stock">
                            @item.Quantity Left
                        </span>
                    }
                    else
                    {
                        <span class="badge-stock in-stock">
                            @item.Quantity In Stock
                        </span>
                    }
                </td>

                @* ADMIN ONLY *@
                @if (isAdmin)
                {
                    <td>
                        UGX @item.BuyingPrice.ToString("N0")
                    </td>
                }

                <td>
                    UGX @item.Price.ToString("N0")
                </td>

                <td>
                    @item.DateAdded.ToString("dd MMM yyyy")
                </td>

                <td>
                    @* ADMIN *@
                    @if (isAdmin)
                    {
                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning action-btn">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger action-btn"
                           onclick="return confirm('Delete this product?')">
                            Delete
                        </a>
                    }

                    @* SELL BUTTON FOR BOTH *@
                    @if (!soldOut)
                    {
                        <a asp-controller="Sales"
                           asp-action="Sell"
                           asp-route-productId="@item.Id"
                           class="btn btn-sm btn-success action-btn">
                            Sell
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-secondary action-btn" disabled>
                            Sold Out
                        </button>
                    }
                </td>
            </tr>

            no++;
        }
     
    </tbody>
</table>
<div class="d-flex justify-content-between align-items-center mt-3">

    <div class="text-muted">
        Showing
        @{
            int start = ((ViewBag.CurrentPage - 1) * 10) + 1;
            int end = Math.Min(ViewBag.CurrentPage * 10, ViewBag.TotalItems);
        }

        <strong>@start</strong>
        -
        <strong>@end</strong>

        of

        <strong>@ViewBag.TotalItems</strong>

        products
    </div>

</div>

@if (ViewBag.TotalPages > 1)
{
    int current = ViewBag.CurrentPage;
    int total = ViewBag.TotalPages;

    <nav class="mt-3">
        <ul class="pagination justify-content-center flex-wrap">

            <!-- PREVIOUS -->
            @if (current > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(current - 1)"
                       asp-route-search="@ViewBag.Search"
                       asp-route-categoryId="@ViewBag.CategoryId">
                        Previous
                    </a>
                </li>
            }

            <!-- FIRST PAGES -->
            @for (int i = 1; i <= Math.Min(3, total); i++)
            {
                <li class="page-item @(i == current ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       asp-route-categoryId="@ViewBag.CategoryId">
                        @i
                    </a>
                </li>
            }

            <!-- DOTS -->
            @if (current > 5)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            <!-- CURRENT AREA -->
            @for (int i = Math.Max(4, current - 1);
                    i <= Math.Min(total - 3, current + 1);
                    i++)
            {
                <li class="page-item @(i == current ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       asp-route-categoryId="@ViewBag.CategoryId">
                        @i
                    </a>
                </li>
            }

            <!-- DOTS -->
            @if (current < total - 4)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }

            <!-- LAST PAGES -->
            @for (int i = Math.Max(total - 2, 4); i <= total; i++)
            {
                <li class="page-item @(i == current ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       asp-route-categoryId="@ViewBag.CategoryId">
                        @i
                    </a>
                </li>
            }

            <!-- NEXT -->
            @if (current < total)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(current + 1)"
                       asp-route-search="@ViewBag.Search"
                       asp-route-categoryId="@ViewBag.CategoryId">
                        Next
                    </a>
                </li>
            }

        </ul>
    </nav>
}
@model dynamic
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    bool isAdmin = User.IsInRole("Admin");

    var activeTab = ViewBag.ActiveTab ?? "daily";
}

<h2 class="mb-4">Business Reports</h2>

<!-- TABS -->
<ul class="nav nav-tabs mb-4">

    <!-- DAILY -->
    <li class="nav-item">
        <button class="nav-link @(activeTab == "daily" ? "active" : "")"
                data-bs-toggle="tab"
                data-bs-target="#daily">
            Daily Sales Report
        </button>
    </li>

    @if (isAdmin)
    {
        <!-- WEEKLY -->
        <li class="nav-item">
            <button class="nav-link @(activeTab == "weekly" ? "active" : "")"
                    data-bs-toggle="tab"
                    data-bs-target="#weekly">
                Weekly Sales Report
            </button>
        </li>

        <!-- RESTOCK -->
        <li class="nav-item">
            <button class="nav-link @(activeTab == "restock" ? "active" : "")"
                    data-bs-toggle="tab"
                    data-bs-target="#restock">
                Restock Reports
            </button>
        </li>
    }

</ul>

<div class="tab-content">

    <!-- DAILY -->
    <div class="tab-pane fade @(activeTab == "daily" ? "show active" : "")" id="daily">

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">

                    <h5 class="mb-0">
                        Sales Report - @DateTime.UtcNow.ToString("dd MMM yyyy")
                    </h5>

                    <a asp-action="ExportDailySales"
                       class="btn btn-success">
                        <i class="fa fa-file-excel me-1"></i>
                        Export Excel
                    </a>

                </div>

                <table class="table table-hover mt-4">

                    <thead class="table-dark">
                        <tr>
                            <th>Receipt</th>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Total</th>
                            <th>Cashier</th>
                            <th>Time</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (ViewBag.DailySales != null && ViewBag.DailySales.Count > 0)
                        {
                            foreach (var s in ViewBag.DailySales)
                            {
                                <tr>
                                    <td>@s.ReceiptNumber</td>
                                    <td>@s.Product?.ProductName</td>
                                    <td>@s.Quantity</td>
                                    <td>UGX @s.TotalAmount.ToString("N0")</td>
                                    <td>@s.CashierName</td>
                                    <td>@s.SaleDate.ToLocalTime().ToString("hh:mm tt")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    No sales found today
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        </div>

    </div>

    @if (isAdmin)
    {
        <!-- WEEKLY -->
        <div class="tab-pane fade @(activeTab == "weekly" ? "show active" : "")" id="weekly">

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">

                    <h5>This Week's Sales</h5>

                    <table class="table table-hover mt-3">

                        <thead class="table-dark">
                            <tr>
                                <th>Receipt</th>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Total</th>
                                <th>Cashier</th>
                                <th>Date</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var s in ViewBag.WeeklySales)
                            {
                                <tr>
                                    <td>@s.ReceiptNumber</td>
                                    <td>@s.Product?.ProductName</td>
                                    <td>@s.Quantity</td>
                                    <td>UGX @s.TotalAmount.ToString("N0")</td>
                                    <td>@s.CashierName</td>
                                    <td>@s.SaleDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            </div>

        </div>

        <!-- RESTOCK -->
        <div class="tab-pane fade @(activeTab == "restock" ? "show active" : "")" id="restock">

            <!-- FILTER -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body">

                    <form method="get" class="row g-3 align-items-end">

                        <input type="hidden" name="activeTab" value="restock" />

                        <div class="col-md-4">

                            <label class="form-label fw-semibold">
                                Filter By Restock Date
                            </label>

                            <input type="date"
                                   name="restockDate"
                                   value="@ViewBag.RestockDate"
                                   class="form-control" />

                        </div>

                        <div class="col-md-2">
                            <button class="btn btn-primary w-100">
                                Filter
                            </button>
                        </div>

                        <div class="col-md-2">
                            <a asp-action="Index"
                               class="btn btn-secondary w-100">
                                Reset
                            </a>
                        </div>

                    </form>

                </div>
            </div>

            @* <!-- CREATE RESTOCK -->
            <div class="d-flex justify-content-between mb-3">

                <h5>Create Restock</h5>

                <button type="button"
                        class="btn btn-primary"

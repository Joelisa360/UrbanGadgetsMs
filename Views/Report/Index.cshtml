            <!-- PREVIOUS REPORTS -->
            <h5 class="mb-3">Recent Restock Reports</h5>

            <table class="table table-bordered table-hover">

                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Report No</th>
                        <th>Total</th>
                        <th>Created By</th>
                        <th width="120">Action</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var r in ViewBag.Restocks)
                    {
                        <tr>
                            <td>@r.ReportDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td>@r.ReportNumber</td>
                            <td>UGX @r.TotalAmount.ToString("N0")</td>
                            <td>@r.CreatedBy</td>
                            <td>
                                <a asp-action="ViewReport"
                                   asp-route-id="@r.Id"
                                   class="btn btn-sm btn-info text-white">
                                    View
                                </a>
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

            <div class="mt-3 text-end">
                <a asp-controller="Report"
                   asp-action="CreateRestock"
                   class="btn btn-primary">
                    + Create Restock
                </a>
            </div>

        </div>
    }

</div>